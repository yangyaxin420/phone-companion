# ============================
# 🎯 骆云影 LoRA 微调 — Colab版
# 在 Google Colab 免费 GPU 上运行
# 训练 Qwen2.5-1.5B + 骆云影对话数据
# ============================

# ---------- 第一步：安装 LLaMA-Factory ----------
# 运行这个单元格

!git clone --depth 1 https://github.com/hiyouga/LLaMA-Factory.git
%cd LLaMA-Factory
!pip install -e ".[torch,metrics]" -q

# ---------- 第二步：挂载 Google Drive ----------
# 这里会弹出授权窗口，点确认就行
# 你的数据文件需要提前上传到 MyDrive

from google.colab import drive
drive.mount('/content/drive')

# ---------- 第三步：复制数据 ----------
# 先在你的 Google Drive 里建一个文件夹叫 luoyunying_data
# 把这两个文件传进去：
#   1. luoyunying_sharegpt.json
#   2. dataset_info.json
# 然后运行这行

!cp /content/drive/MyDrive/luoyunying_data/*.json /content/LLaMA-Factory/data/

# 确认数据到位了
!ls -la /content/LLaMA-Factory/data/luoyunying_sharegpt.json
!wc -l /content/LLaMA-Factory/data/luoyunying_sharegpt.json

# ---------- 第四步：检查 GPU ----------
# 确认 Colab 给你分配了 T4

!nvidia-smi
print("✅ GPU 就绪")

# ---------- 第五步：开始训练 ----------
# 这个会跑大约 15-20 分钟

!llamafactory-cli train \
  --stage sft \
  --model_name_or_path Qwen/Qwen2.5-1.5B \
  --dataset luoyunying \
  --dataset_dir data \
  --template default \
  --finetuning_type lora \
  --lora_target all \
  --lora_rank 8 \
  --lora_alpha 16 \
  --output_dir saves/luoyunying_lora \
  --overwrite_output_dir \
  --per_device_train_batch_size 4 \
  --gradient_accumulation_steps 4 \
  --lr_scheduler_type cosine \
  --learning_rate 2e-4 \
  --num_train_epochs 3.0 \
  --logging_steps 5 \
  --save_steps 100 \
  --plot_loss \
  --report_to none \
  --trust_remote_code

print("✅ 训练完成！")

# ---------- 第六步：合并 + 导出模型 ----------
# 把 LoRA 权重合并到基础模型，导出完整模型

!llamafactory-cli export \
  --model_name_or_path Qwen/Qwen2.5-1.5B \
  --adapter_name_or_path saves/luoyunying_lora \
  --template default \
  --finetuning_type lora \
  --export_dir saves/luoyunying_merged \
  --export_size 2 \
  --trust_remote_code

print("✅ 模型合并完成！")

# ---------- 第七步：打包下载 ----------
# 压缩成 zip，方便下载到本地

!cd saves && zip -r /content/luoyunying_lora.zip luoyunying_lora/
!zip -r /content/luoyunying_merged.zip saves/luoyunying_merged/

# 同时也复制到你的 Google Drive 备份一份
!cp /content/luoyunying_lora.zip /content/drive/MyDrive/luoyunying_data/
!cp /content/luoyunying_merged.zip /content/drive/MyDrive/luoyunying_data/

print("✅ 已保存到 Google Drive")
print("📥 也可以从这里下载：")
from IPython.display import FileLink
display(FileLink('/content/luoyunying_lora.zip'))
display(FileLink('/content/luoyunying_merged.zip'))
